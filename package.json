{
  "name": "cstm-changeset",
  "version": "1.0.3",
  "description": "A changeset add wrapper that prompts for structured business context",
  "type": "module",
  "author": "Paul Morar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulmorar/cstm-changeset.git"
  },
  "homepage": "https://github.com/paulmorar/cstm-changeset#readme",
  "bugs": {
    "url": "https://github.com/paulmorar/cstm-changeset/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "cstm-changeset": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@changesets/cli": ">=2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "changesets",
    "changelog",
    "cli",
    "versioning",
    "release"
  ],
  "license": "MIT"
}
